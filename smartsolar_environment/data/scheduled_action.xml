<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ir_cron_fetch_environment" model="ir.cron">
            <field name="name">SmartSolar: Fetch environment data</field>
            <field name="model_id" ref="smartsolar.model_smartsolar_system"/>
            <field name="state">code</field>
            <field name="code">model._cron_fetch_environment()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
